# Google Drive source and destination folders
GDRIVE_RAW_FOLDER_ID=xxxxxxxxxxxxxxxxxxxx
GDRIVE_PROCESSED_FOLDER_ID=yyyyyyyyyyyyyyyyyyyy

# Service Account JSON in base64 (recommended in CI)
GDRIVE_SERVICE_ACCOUNT_JSON_B64=

# Optional: local path to service account json (for local tests)
# GDRIVE_SERVICE_ACCOUNT_FILE=/absolute/path/service-account.json

# ETL behavior
TZ=America/Caracas
REPORTS_OUTPUT_DIR=data/processed
OUTPUT_MODE=both
# both | local | drive

# Backend API behavior
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RESUMEN_HISTORICO_FILENAME=asistencia_resumen_diario_historico.csv
EVENTOS_HISTORICO_FILENAME=asistencia_eventos_historico.csv
METADATA_HISTORICO_FILENAME=asistencia_metadata_historico.json

# Supabase (Auth + gestión de usuarios/roles)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
