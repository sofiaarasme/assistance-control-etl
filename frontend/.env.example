# Supabase (cliente público)
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxx

# Google OAuth Web Client (NO usar client secret en frontend)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Opción recomendada: una sola carpeta de Drive con todos los CSV mensuales
VITE_GOOGLE_DRIVE_FOLDER_ID=

# Opción alternativa: IDs de archivos CSV específicos, separados por coma
# Ejemplo: 1abc...,1def...,1ghi...
VITE_GOOGLE_DRIVE_FILE_IDS=
